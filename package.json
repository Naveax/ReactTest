{
  "name": "certificate-monorepo",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "node ./scripts/dev-all.cjs",
    "dev:api": "bun run ./scripts/dev-api.cjs",
    "dev:web": "cd apps/web && bun run --bun dev",
    "doctor": "node ./scripts/doctor.cjs",
    "test:smoke": "node ./scripts/smoke-api.cjs",
    "setup": "bun run setup:api && bun run setup:web",
    "setup:api": "bun run ./scripts/setup-api.cjs",
    "setup:web": "cd apps/web && bun install",
    "build": "bun run build:web",
    "build:web": "cd apps/web && bun run --bun build",
    "preview": "cd apps/web && bun run --bun preview"
  },
  "devDependencies": {}
}
